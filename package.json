{
  "name": "review-plugin-mvp",
  "displayName": "Review Plugin MVP",
  "description": "VS Code extension for sequential, one-at-a-time PR review",
  "version": "0.0.1",
  "publisher": "ktrz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ktrz/review-plugin-mvp.git"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reviewPlugin.loadFindings",
        "title": "Load review findings",
        "category": "Review Plugin"
      },
      {
        "command": "reviewPlugin.thread.post",
        "title": "Post",
        "category": "Review",
        "icon": "$(check)"
      },
      {
        "command": "reviewPlugin.thread.dismiss",
        "title": "Dismiss",
        "category": "Review",
        "icon": "$(circle-slash)"
      },
      {
        "command": "reviewPlugin.thread.discuss",
        "title": "Discuss",
        "category": "Review",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "reviewPlugin.thread.unresolve",
        "title": "Unresolve",
        "category": "Review",
        "icon": "$(refresh)"
      },
      {
        "command": "reviewPlugin.session.finalize",
        "title": "Finalize session",
        "category": "Review"
      },
      {
        "command": "reviewPlugin.chat.send",
        "title": "Send",
        "category": "Review",
        "icon": "$(send)"
      },
      {
        "command": "reviewPlugin.thread.finalizeChat",
        "title": "Finalize chat (custom)",
        "category": "Review",
        "icon": "$(milestone)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "reviewPlugin.session.finalize",
          "when": "reviewPlugin.hasFindings"
        },
        {
          "command": "reviewPlugin.chat.send",
          "when": "false"
        },
        {
          "command": "reviewPlugin.thread.finalizeChat",
          "when": "false"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "reviewPlugin.thread.post",
          "when": "commentThread =~ /review-finding-(unresolved|deferred)/",
          "group": "inline@1"
        },
        {
          "command": "reviewPlugin.thread.dismiss",
          "when": "commentThread =~ /review-finding-(unresolved|deferred)/",
          "group": "inline@2"
        },
        {
          "command": "reviewPlugin.thread.discuss",
          "when": "commentThread =~ /review-finding-(unresolved|deferred)/",
          "group": "inline@3"
        },
        {
          "command": "reviewPlugin.thread.finalizeChat",
          "when": "commentThread =~ /review-finding-deferred-chatting/",
          "group": "inline@0"
        },
        {
          "command": "reviewPlugin.thread.unresolve",
          "when": "commentThread =~ /review-finding-(resolved|skipped|custom)/",
          "group": "inline@1"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "reviewPlugin.chat.send",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Review Plugin",
      "properties": {
        "reviewPlugin.claude.cliPath": {
          "type": "string",
          "default": "claude",
          "description": "Path to the claude CLI binary used for chat replies."
        },
        "reviewPlugin.claude.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra argv appended after `-p` when invoking the claude CLI."
        },
        "reviewPlugin.shaCheck.mode": {
          "type": "string",
          "enum": ["warn", "off"],
          "default": "warn",
          "description": "How to handle a Head SHA mismatch between the loaded findings doc and the workspace's git HEAD."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "vsce package",
    "install:local": "npm run compile && vsce package -o review-plugin-mvp-local.vsix && code --install-extension review-plugin-mvp-local.vsix",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.27.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  }
}
